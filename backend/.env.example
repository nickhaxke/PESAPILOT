# PesaPilot Production Environment Variables
# Copy this to .env and fill in your values

# Server settings
PORT=5000
NODE_ENV=production

# Database - PostgreSQL (Supabase or other)
# Option 1: Use DATABASE_URL for Supabase/Render/Railway
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Option 2: Use individual settings (fallback if DATABASE_URL not set)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=pesapilot
DB_PORT=5432

# Enable SSL for production databases (required for Supabase)
DB_SSL=true

# JWT Secret - Generate a strong random string
JWT_SECRET=y02PaMqCANgmLCD8cHacGPhaNuZ/pi12TFoNaDfktus=
JWT_EXPIRES_IN=7d
